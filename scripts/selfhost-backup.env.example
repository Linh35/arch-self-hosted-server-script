# Copy to ~/.config/selfhost-backup.env and `chmod 600` it. scripts/backup.sh
# sources this to know WHERE to push restic snapshots and how to authenticate.
# Switching providers is a one-line change to RESTIC_REPOSITORY (+ its creds).
#
#   cp scripts/selfhost-backup.env.example ~/.config/selfhost-backup.env
#   chmod 600 ~/.config/selfhost-backup.env
#   $EDITOR ~/.config/selfhost-backup.env

# --- Encryption (REQUIRED) -------------------------------------------------
# restic encrypts every snapshot client-side, so the provider only ever stores
# ciphertext. Generate once with:  openssl rand -base64 32
# Store it somewhere safe and OFFLINE too: lose it and the backups are
# permanently unrecoverable — there is no reset.
export RESTIC_PASSWORD='CHANGE-ME-long-random-string'

# --- Backblaze B2 (active) -------------------------------------------------
# In the B2 console: create a (private) bucket, then an Application Key scoped
# to it. Put the bucket name after "b2:" and a path/prefix after the second ":".
export RESTIC_REPOSITORY="b2:YOUR-BUCKET-NAME:selfhost"
export B2_ACCOUNT_ID="YOUR-APPLICATION-KEY-ID"
export B2_ACCOUNT_KEY="YOUR-APPLICATION-KEY"

# --- Cloudflare R2 (alternative) — comment the B2 block, uncomment these ----
# export RESTIC_REPOSITORY="s3:https://<ACCOUNT_ID>.r2.cloudflarestorage.com/YOUR-BUCKET/selfhost"
# export AWS_ACCESS_KEY_ID="YOUR-R2-ACCESS-KEY-ID"
# export AWS_SECRET_ACCESS_KEY="YOUR-R2-SECRET-ACCESS-KEY"

# --- Local disk (alternative) ----------------------------------------------
# export RESTIC_REPOSITORY="/mnt/usb/restic"
