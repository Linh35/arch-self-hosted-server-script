# Shared defaults. Each compose/ stack also has its own .env.example —
# real secrets (passwords) live only in those, not here.

DOMAIN=example.com
TZ=Europe/London
PUID=1000
PGID=1000

# Where all service data lives. Point this at your btrfs RAID pool mount
# (see scripts/storage.sh). ./scripts/manage.sh exports it to every stack.
# Leave it commented to fall back to the in-repo data/ directory.
# STORAGE_ROOT=/srv/storage
