TZ=Europe/London
# IMPORTANT: keep PUID/PGID NON-root. Unlike the other stacks (which use 0),
# FreshRSS's php-fpm refuses to run as root ("please specify user and group
# other than root" -> nginx 502). Use 1000 (or any non-zero uid/gid).
PUID=1000
PGID=1000

# STORAGE_ROOT is read from the repo-root .env by ./scripts/manage.sh.
# If you run podman-compose directly, set it here too (else data/ is used).
# STORAGE_ROOT=/srv/storage

# FreshRSS has no env-based admin provisioning — create the admin account in
# the first-run web installer (choose SQLite for the database).
