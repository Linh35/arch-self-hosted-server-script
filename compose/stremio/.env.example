TZ=Europe/London

# LAN ranges that should bypass the VPN inside gluetun, so devices on
# your network can hit the Stremio server directly without routing through
# the tunnel.
LAN_SUBNETS=192.168.0.0/16,10.0.0.0/8

# --- VPN ---
# Provider list and the exact variable names each one needs:
#   https://github.com/qdm12/gluetun-wiki
#
# Example: Mullvad WireGuard
VPN_SERVICE_PROVIDER=mullvad
VPN_TYPE=wireguard
WIREGUARD_PRIVATE_KEY=
WIREGUARD_ADDRESSES=
SERVER_COUNTRIES=Netherlands
SERVER_CITIES=

# For OpenVPN-based providers, set these instead and clear the WireGuard ones:
OPENVPN_USER=
OPENVPN_PASSWORD=
