TZ=Europe/London

# STORAGE_ROOT is read from the repo-root .env by ./scripts/manage.sh.
# If you run podman-compose directly, set it here too (else data/ is used).
# STORAGE_ROOT=/srv/storage

# Your server's LAN IP, so the Stremio web UI points the streaming server at
# this machine instead of the browser's own localhost. Required for streaming
# to work from a browser on another device.
STREMIO_IP=
