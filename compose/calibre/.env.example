TZ=Europe/London
PUID=1000
PGID=1000

# STORAGE_ROOT is read from the repo-root .env by ./scripts/manage.sh.
# If you run podman-compose directly, set it here too (else data/ is used).
# STORAGE_ROOT=/srv/storage

# NOTE: the Calibre desktop GUI on :8080 runs without auth on purpose (LAN +
# WARP-tunnel only). To lock it, add PASSWORD (and USER) directly to the
# calibre service's environment in docker-compose.yml — see the comment there.
# A standalone CALIBRE_GUI_PASSWORD var is NOT wired up and does nothing.
