# *arr stack (Prowlarr/Radarr/Sonarr/Bazarr) + qBittorrent.
# linuxserver images run as this user (set 0 = root to match the rest of this stack).
TZ=Europe/London
PUID=1000
PGID=1000

# STORAGE_ROOT is read from the repo-root .env by ./scripts/manage.sh.
# If you run podman-compose directly, set it here too (else data/ is used).
# STORAGE_ROOT=/srv/storage

# No VPN for qBittorrent right now — torrent traffic exits on the host IP.
# To add a VPN later, re-introduce a gluetun service (NordVPN WireGuard works:
# VPN_SERVICE_PROVIDER=nordvpn, VPN_TYPE=wireguard, WIREGUARD_PRIVATE_KEY=...)
# and point qbittorrent at it with network_mode: "service:gluetun".
