TZ=Europe/London
PUID=1000
PGID=1000

# STORAGE_ROOT is read from the repo-root .env by ./scripts/manage.sh.
# If you run podman-compose directly, set it here too (else data/ is used).
# STORAGE_ROOT=/srv/storage

# Navidrome auto-creates an admin user on first run (it has no anonymous mode).
# Login is admin / this password. Change it before first boot if you like.
NAVIDROME_ADMIN_PASSWORD=admin
