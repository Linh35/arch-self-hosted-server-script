# Use the SAME PUID/PGID as the *arr stack (compose/arr/.env) so Jellyfin can
# read the shared /mnt/storage/data library. This deployment runs the *arr
# stack as 0 (root, which maps to your host user under rootless podman).
TZ=Europe/London
PUID=1000
PGID=1000

# STORAGE_ROOT is read from the repo-root .env by ./scripts/manage.sh.
# If you run podman-compose directly, set it here too (else data/ is used).
# STORAGE_ROOT=/srv/storage

# No secrets here — create the admin account in Jellyfin's first-run web wizard
# and point a library at /data/movies (and /data/tv, etc.).
