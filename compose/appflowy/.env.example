# AppFlowy-Cloud configuration. Copy to .env (gitignored) and fill in.
#
# IMPORTANT: unlike the upstream deploy.env, values here are written out in full
# (no ${VAR} cross-references) because podman-compose does not reliably expand
# variables defined within a .env file. If you change the domain or the DB
# password, update EVERY line that mentions it.

# --- Public URL -------------------------------------------------------------
# The subdomain Caddy serves (flowy.<your DOMAIN>). Caddy terminates TLS, so
# these are https/wss even though the internal nginx speaks plain http.
APPFLOWY_BASE_URL=https://flowy.example.com
APPFLOWY_WEB_URL=https://flowy.example.com
APPFLOWY_WEBSOCKET_BASE_URL=wss://flowy.example.com/ws/v2
API_EXTERNAL_URL=https://flowy.example.com/gotrue
APPFLOWY_S3_PRESIGNED_URL_ENDPOINT=https://flowy.example.com/minio-api

# Host port the internal nginx is published on; Caddy proxies flowy.<DOMAIN>
# here. Must match the reverse_proxy target in compose/caddy/Caddyfile.
APPFLOWY_PORT=9000

# --- Postgres ---------------------------------------------------------------
# CHANGE the password. It also appears in the two DATABASE_URL lines below —
# keep all three in sync. If the password has URL-special chars (@ : / etc.),
# url-encode it in the URLs (e.g. @ -> %40).
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_db_password
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=postgres
APPFLOWY_DATABASE_URL=postgres://postgres:CHANGE_ME_db_password@postgres:5432/postgres
GOTRUE_DATABASE_URL=postgres://postgres:CHANGE_ME_db_password@postgres:5432/postgres?search_path=auth
APPFLOWY_DATABASE_MAX_CONNECTIONS=40

# --- Redis ------------------------------------------------------------------
APPFLOWY_REDIS_URI=redis://redis:6379

# --- Auth (GoTrue) ----------------------------------------------------------
# Admin login for the console at https://flowy.example.com/console
GOTRUE_ADMIN_EMAIL=you@example.com
GOTRUE_ADMIN_PASSWORD=CHANGE_ME_admin_password
# JWT signing secret — generate with: openssl rand -hex 32
GOTRUE_JWT_SECRET=CHANGE_ME_run_openssl_rand_hex_32
GOTRUE_JWT_EXP=604800
APPFLOWY_GOTRUE_BASE_URL=http://gotrue:9999

# Auto-confirm signups so you can create your account without SMTP. After you
# have registered, set GOTRUE_DISABLE_SIGNUP=true to lock the instance down
# (and/or configure SMTP below + set GOTRUE_MAILER_AUTOCONFIRM=false).
GOTRUE_MAILER_AUTOCONFIRM=true
GOTRUE_DISABLE_SIGNUP=false
GOTRUE_RATE_LIMIT_EMAIL_SENT=100

# --- SMTP (optional; required for email confirmation / invites) -------------
# Leave as-is if GOTRUE_MAILER_AUTOCONFIRM=true. smtps (TLS) is used for 465.
GOTRUE_SMTP_HOST=smtp.example.com
GOTRUE_SMTP_PORT=465
GOTRUE_SMTP_USER=
GOTRUE_SMTP_PASS=
GOTRUE_SMTP_ADMIN_EMAIL=you@example.com
APPFLOWY_MAILER_SMTP_HOST=smtp.example.com
APPFLOWY_MAILER_SMTP_PORT=465
APPFLOWY_MAILER_SMTP_USERNAME=
APPFLOWY_MAILER_SMTP_EMAIL=you@example.com
APPFLOWY_MAILER_SMTP_PASSWORD=
APPFLOWY_MAILER_SMTP_TLS_KIND=wrapper   # none | wrapper | required | opportunistic

# --- Object storage (MinIO) -------------------------------------------------
# CHANGE these from the minioadmin defaults. Used as the MinIO root creds AND
# AppFlowy's S3 keys.
APPFLOWY_S3_USE_MINIO=true
APPFLOWY_S3_CREATE_BUCKET=true
APPFLOWY_S3_MINIO_URL=http://minio:9000
APPFLOWY_S3_ACCESS_KEY=CHANGE_ME_minio_user
APPFLOWY_S3_SECRET_KEY=CHANGE_ME_minio_password
APPFLOWY_S3_BUCKET=appflowy

# --- AI (optional) ----------------------------------------------------------
# Core AppFlowy works with AI off. To enable AI chat / semantic search, set
# AI_ENABLED=true, add your key, and uncomment the `ai` service (see README).
AI_ENABLED=false
AI_OPENAI_API_KEY=

# Log verbosity for the rust services
RUST_LOG=info

# STORAGE_ROOT is inherited from the repo-root .env via scripts/manage.sh and
# decides where postgres/ and minio/ data live. Set it here too only if you run
# podman-compose directly in this directory.
# STORAGE_ROOT=/srv/storage
