TZ=Europe/London

# STORAGE_ROOT is read from the repo-root .env by ./scripts/manage.sh.
# If you run podman-compose directly, set it here too (else data/ is used).
# STORAGE_ROOT=/srv/storage

# No secrets here — Jellyseerr is configured in its first-run web wizard:
# sign in with your Jellyfin account, then connect Radarr/Sonarr using their
# URLs (http://<server-ip>:7878 / :8989) and API keys.
