TZ=Europe/London
PUID=1000
PGID=1000

# STORAGE_ROOT is read from the repo-root .env by ./scripts/manage.sh.
# If you run podman-compose directly, set it here too (else data/ is used).
# STORAGE_ROOT=/srv/storage

# Copyparty runs anonymously (no accounts) — full read/write on the LAN/tunnel.
# To require a login instead, add `-a user:pass` and scope the volume to that
# user (`/w::rwmda,user`) in the compose command.
