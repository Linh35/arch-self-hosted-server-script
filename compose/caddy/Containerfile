# Caddy with the Cloudflare DNS module compiled in. The base image can't do
# the DNS-01 challenge on its own, so we build once here; the running image is
# then ready for EITHER tls mode (internal CA or Cloudflare DNS) with no
# rebuild — switching is a one-line edit in the Caddyfile.
FROM docker.io/library/caddy:2-builder AS build
RUN xcaddy build --with github.com/caddy-dns/cloudflare

FROM docker.io/library/caddy:2
COPY --from=build /usr/bin/caddy /usr/bin/caddy
