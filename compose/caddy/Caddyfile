# Reverse proxy for the whole stack. Each service is reached by name over
# HTTPS instead of ip:port. {$DOMAIN} and {$UPSTREAM_HOST} come from the
# environment (compose/caddy/.env).

# --- TLS mode -------------------------------------------------------------
# Default: publicly-trusted certs via the Cloudflare DNS-01 challenge. No
# browser warnings (works for Amperfy on iOS, etc.), and it needs no inbound
# ports, so it still works even though nothing is published publicly. Requires
# a domain on Cloudflare and CLOUDFLARE_API_TOKEN in compose/caddy/.env (a
# scoped token with Zone:Read + DNS:Edit).
#
# No Cloudflare / offline? Comment out the `tls` block below and uncomment
# `tls internal` to fall back to Caddy's built-in CA — HTTPS with zero
# external dependency, but install Caddy's root (written to /data) on your
# devices to silence warnings.
(tls) {
	tls {
		dns cloudflare {$CLOUDFLARE_API_TOKEN}
		resolvers 1.1.1.1
	}
	# tls internal
}

# Shared per-site setup: TLS as configured above, plus response compression.
(site) {
	import tls
	encode zstd gzip
}

# --- Services -------------------------------------------------------------
# Each block maps a hostname to a service's published port on the host. Add a
# matching DNS record (or hosts entry) pointing the name at the server's LAN
# IP — see the README. Comment out any service you don't run.

photos.{$DOMAIN} {
	import site
	reverse_proxy {$UPSTREAM_HOST}:2283   # Immich
}

music.{$DOMAIN} {
	import site
	reverse_proxy {$UPSTREAM_HOST}:4533   # Navidrome
}

files.{$DOMAIN} {
	import site
	reverse_proxy {$UPSTREAM_HOST}:3923   # Copyparty
}

books.{$DOMAIN} {
	import site
	reverse_proxy {$UPSTREAM_HOST}:8080   # Calibre desktop GUI
}

read.{$DOMAIN} {
	import site
	reverse_proxy {$UPSTREAM_HOST}:8083   # Calibre-Web
}

rss.{$DOMAIN} {
	import site
	reverse_proxy {$UPSTREAM_HOST}:8082   # FreshRSS
}

# --- *arr stack -----------------------------------------------------------
prowlarr.{$DOMAIN} {
	import site
	reverse_proxy {$UPSTREAM_HOST}:9696   # Prowlarr (indexer manager)
}

radarr.{$DOMAIN} {
	import site
	reverse_proxy {$UPSTREAM_HOST}:7878   # Radarr (movies)
}

sonarr.{$DOMAIN} {
	import site
	reverse_proxy {$UPSTREAM_HOST}:8989   # Sonarr (TV)
}

bazarr.{$DOMAIN} {
	import site
	reverse_proxy {$UPSTREAM_HOST}:6767   # Bazarr (subtitles)
}

qbit.{$DOMAIN} {
	import site
	reverse_proxy {$UPSTREAM_HOST}:8088   # qBittorrent
}

# --- AppFlowy -------------------------------------------------------------
# Single host front door: AppFlowy's own nginx (compose/appflowy) does the
# internal path routing for /api, /ws, /gotrue, /minio, /console and the web
# UI. Caddy just terminates TLS and forwards everything — WebSockets and SSE
# pass through reverse_proxy unchanged. Keep APPFLOWY_PORT in sync with
# compose/appflowy/.env.
flowy.{$DOMAIN} {
	import site
	reverse_proxy {$UPSTREAM_HOST}:9000   # AppFlowy (internal nginx router)
}
