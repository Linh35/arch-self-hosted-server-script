# After `cloudflared tunnel create selfhost`, copy this to config.yml
# (gitignored) and paste the UUID in both places below. The system service
# reads /etc/cloudflared/config.yml and looks for credentials in
# /etc/cloudflared/<UUID>.json — so copy both there before enabling it:
#
#   sudo cp cloudflared/config.yml /etc/cloudflared/
#   sudo cp ~/.cloudflared/<UUID>.json /etc/cloudflared/
#
# This config runs the tunnel in PRIVATE NETWORK mode (WARP-to-Tunnel).
# Nothing is published on a public hostname. The tunnel only forwards
# traffic for the private CIDR routed to it (see README), and only devices
# running the Cloudflare WARP client enrolled in your Zero Trust org can
# reach it. Services stay LAN-only; the tunnel is just the VPN path in.

tunnel: REPLACE_WITH_TUNNEL_UUID
credentials-file: /etc/cloudflared/REPLACE_WITH_TUNNEL_UUID.json

# Route private IP traffic from WARP clients into the LAN.
warp-routing:
  enabled: true

# No public ingress. The catch-all 404 is required when an `ingress`
# block is present, but with WARP routing you can omit `ingress` entirely.
# Left here (returning 404 for any stray public request) as a safety net.
ingress:
  - service: http_status:404
